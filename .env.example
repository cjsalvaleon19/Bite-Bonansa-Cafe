# ─────────────────────────────────────────────────────────────────────────────
# Bite Bonansa Café — Environment Variables
#
# 1. Copy this file to .env.local  (never commit .env.local to git)
# 2. Fill in the values from your Supabase project:
#    Supabase Dashboard → Project Settings → API
# 3. For Vercel deployments set the same variables in:
#    Vercel Dashboard → Project → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# Public Supabase project URL — safe to expose to the browser (NEXT_PUBLIC_*)
# Example: https://abcdefghij.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Public anonymous/read key — safe to expose to the browser (NEXT_PUBLIC_*)
# Found at: Supabase Dashboard → Project Settings → API → anon / public
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ⚠️  SECRET — never expose this key to the browser or commit it to git.
# Required for server-side operations (registration, admin tasks).
# Found at: Supabase Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
