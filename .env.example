# Supabase project URL (found in: Supabase Dashboard > Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anonymous/public key (found in: Supabase Dashboard > Project Settings > API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key - KEEP SECRET, never expose to client
# (found in: Supabase Dashboard > Project Settings > API > service_role key)
# Required for server-side operations (registration, admin tasks)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Base URL of the app (e.g. http://localhost:3000 for local dev)
NEXT_PUBLIC_API_URL=http://localhost:3000

# Android Tablet APK target server URL (same WiFi network as tablet)
# Example: http://192.168.1.100:3000
ANDROID_SERVER_URL=http://192.168.1.100:3000

# Location Services - Using OpenStreetMap + Nominatim
# No API key required! The app uses free OpenStreetMap tiles and Nominatim geocoding service
# for delivery address location selection and search functionality
